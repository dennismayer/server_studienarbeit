<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sprechstunden – Professorenportal</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:        #f5f2ee;
    --surface:   #ffffff;
    --accent:    #2b5cad;
    --accent2:   #d4691e;
    --text:      #1a1a2e;
    --muted:     #7a7a8c;
    --border:    #e0dbd4;
    --slot:      #dde9f7;
    --slot-text: #1e3a6e;
    --repeat:    #fdecd8;
    --repeat-text:#7a3010;
    --shadow:    0 8px 40px rgba(43,92,173,.13);
    --radius:    14px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    padding: 32px 16px 64px;
  }

  /* ── Header ── */
  .header {
    max-width: 1080px;
    width: 100%;
    margin: 0 auto 14px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .header-title {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    line-height: 1.1;
    color: var(--text);
  }
  .header-title span { color: var(--accent); font-style: italic; }
  .header-sub { font-size: .85rem; color: var(--muted); margin-top: 4px; }

  .app-layout {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    padding-left: 260px;
  }
  .sidebar {
    position: fixed;
    left: 16px;
    top: 32px;
    width: 220px;
    background: transparent;
    border: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .sidebar-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 24px 18px 18px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .sidebar-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1.1rem;
    margin-bottom: 14px;
    color: var(--text);
  }
  .sidebar-item {
    text-align: left;
    border: none;
    background: transparent;
    color: var(--text);
    padding: 12px 14px;
    border-radius: 12px;
    cursor: pointer;
    font-size: .95rem;
    transition: background .2s, color .2s;
  }
  .sidebar-item:hover {
    background: var(--slot);
  }
  .sidebar-item.active {
    background: var(--accent);
    color: #fff;
  }
  .main-content {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 1080px;
    width: 100%;
    margin: 0 auto;
  }
  .logout-top {
    position: fixed;
    top: 24px;
    right: 24px;
    z-index: 200;
  }
  .logout-form {
    margin: 0;
  }
  .logout-btn {
    padding: 10px 16px;
    background: var(--accent2);
    color: #fff;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    font-family: inherit;
    font-size: .9rem;
    transition: background .2s;
  }
  .logout-btn:hover {
    background: #be5b1d;
  }

  .month-nav {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 50px;
  }
  .month-label {
    font-family: 'DM Serif Display', serif;
    font-size: 1.25rem;
    min-width: 200px;
    text-align: center;
  }
  .header-title {
    margin-right: auto;
  }
  .nav-btn {
    width: 38px; height: 38px;
    border-radius: 50%;
    border: 1.5px solid var(--border);
    background: var(--surface);
    cursor: pointer;
    font-size: 1.1rem;
    color: var(--text);
    display: flex; align-items: center; justify-content: center;
    transition: background .2s, border-color .2s;
  }
  .nav-btn:hover { background: var(--accent); color: #fff; border-color: var(--accent); }

  /* ── Calendar grid ── */
  .cal-wrap {
    max-width: 1080px;
    width: min(100%, calc(100vw - 320px));
    margin: 0 auto;
    background: var(--surface);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .cal-weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    background: var(--accent);
    padding: 10px 4px;
  }
  .cal-weekdays div {
    text-align: center;
    color: rgba(255,255,255,.85);
    font-size: .75rem;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
  }

  .cal-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 1px;
    background: var(--border);
    padding: 1px;
  }

  .cal-cell {
    background: var(--surface);
    min-height: 90px;
    padding: 8px 6px 6px;
    cursor: pointer;
    transition: background .15s;
    position: relative;
  }
  .cal-cell:hover { background: #f0eefc; }
  .cal-cell.other-month { background: #faf9f7; }
  .cal-cell.other-month .day-num { color: #c8c4bc; }
  .cal-cell.today .day-num {
    background: var(--accent);
    color: #fff;
    border-radius: 50%;
    width: 26px; height: 26px;
    display: flex; align-items: center; justify-content: center;
    font-weight: 600;
  }

  .day-num {
    font-size: .85rem;
    font-weight: 500;
    margin-bottom: 4px;
    width: 26px; height: 26px;
    display: flex; align-items: center; justify-content: center;
  }

  .slot-pill {
    font-size: .68rem;
    background: var(--slot);
    color: var(--slot-text);
    border-radius: 5px;
    padding: 2px 5px;
    margin-bottom: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: flex;
    align-items: center;
    gap: 3px;
  }
  .slot-pill.repeat {
    background: var(--repeat);
    color: var(--repeat-text);
  }
  .slot-pill .dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: currentColor;
    flex-shrink: 0;
  }
  .more-slots {
    font-size: .65rem;
    color: var(--muted);
    padding: 1px 4px;
  }

  /* ── Legend ── */
  .legend {
    max-width: 1080px;
    margin: 16px auto 0;
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: .78rem;
    color: var(--muted);
  }
  .legend-dot {
    width: 10px; height: 10px;
    border-radius: 3px;
  }

  /* ── Modal overlay ── */
  .overlay {
    display: none;
    position: fixed; inset: 0;
    background: rgba(20,20,40,.45);
    backdrop-filter: blur(4px);
    z-index: 100;
    align-items: center;
    justify-content: center;
    padding: 16px;
  }
  .overlay.open { display: flex; }

  .modal {
    background: var(--surface);
    border-radius: var(--radius);
    width: 100%;
    max-width: 540px;
    max-height: 90vh;
    overflow-y: auto;
    box-shadow: 0 24px 60px rgba(0,0,0,.22);
    animation: slideUp .25s ease;
  }
  @keyframes slideUp {
    from { opacity:0; transform: translateY(24px); }
    to   { opacity:1; transform: translateY(0); }
  }

  .modal-header {
    padding: 24px 28px 16px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
  }
  .modal-header h2 {
    font-family: 'DM Serif Display', serif;
    font-size: 1.5rem;
    line-height: 1.2;
  }
  .modal-header .modal-date-sub {
    font-size: .8rem;
    color: var(--muted);
    margin-top: 2px;
  }
  .close-btn {
    width: 32px; height: 32px;
    border-radius: 50%;
    border: 1.5px solid var(--border);
    background: transparent;
    cursor: pointer;
    font-size: 1.1rem;
    color: var(--muted);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: background .2s, color .2s;
  }
  .close-btn:hover { background: var(--text); color: #fff; border-color: var(--text); }

  /* Existing slots list */
  .slots-section {
    padding: 20px 28px 0;
  }
  .slots-section h3 {
    font-size: .75rem;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 10px;
  }
  .slot-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    background: var(--bg);
    border-radius: 10px;
    margin-bottom: 6px;
    font-size: .875rem;
  }
  .slot-row .time-badge {
    font-weight: 600;
    color: var(--accent);
    min-width: 110px;
    font-size: .82rem;
  }
  .slot-row .slot-title-text {
    flex: 1;
    color: var(--text);
  }
  .slot-row .repeat-badge {
    font-size: .68rem;
    background: var(--repeat);
    color: var(--repeat-text);
    border-radius: 20px;
    padding: 2px 8px;
    white-space: nowrap;
  }
  .slot-row .delete-slot {
    width: 24px; height: 24px;
    border-radius: 50%;
    border: none;
    background: transparent;
    cursor: pointer;
    color: #c0bab2;
    font-size: .9rem;
    display: flex; align-items: center; justify-content: center;
    transition: color .2s, background .2s;
  }
  .slot-row .delete-slot:hover { color: #c0392b; background: #fce8e6; }
  .no-slots {
    font-size: .85rem;
    color: var(--muted);
    padding: 8px 0 4px;
    font-style: italic;
  }

  /* Add slot form */
  .add-section {
    padding: 20px 28px 28px;
  }
  .add-section h3 {
    font-size: .75rem;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 14px;
  }
  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .form-group.full { grid-column: 1/-1; }
  .form-group label {
    font-size: .78rem;
    font-weight: 500;
    color: var(--muted);
  }
  .form-group input, .form-group select, .form-group textarea {
    padding: 9px 12px;
    border: 1.5px solid var(--border);
    border-radius: 9px;
    font-family: inherit;
    font-size: .875rem;
    background: var(--bg);
    color: var(--text);
    transition: border-color .2s;
    outline: none;
  }
  .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
    border-color: var(--accent);
    background: #fff;
  }

  /* Toggle repeat */
  .repeat-toggle-wrap {
    grid-column: 1/-1;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: var(--bg);
    border-radius: 10px;
    border: 1.5px solid transparent;
    cursor: pointer;
    transition: border-color .2s;
    user-select: none;
  }
  .repeat-toggle-wrap.active {
    border-color: var(--accent2);
    background: #fef6ee;
  }
  .toggle-switch {
    width: 38px; height: 22px;
    background: var(--border);
    border-radius: 11px;
    position: relative;
    flex-shrink: 0;
    transition: background .2s;
  }
  .toggle-switch::after {
    content: '';
    width: 16px; height: 16px;
    background: #fff;
    border-radius: 50%;
    position: absolute;
    top: 3px; left: 3px;
    transition: transform .2s;
    box-shadow: 0 1px 4px rgba(0,0,0,.2);
  }
  .repeat-toggle-wrap.active .toggle-switch { background: var(--accent2); }
  .repeat-toggle-wrap.active .toggle-switch::after { transform: translateX(16px); }
  .toggle-label { font-size: .875rem; font-weight: 500; }
  .toggle-sub { font-size: .75rem; color: var(--muted); margin-left: auto; }

  /* Submit button */
  .submit-btn {
    width: 100%;
    margin-top: 16px;
    padding: 12px;
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-family: inherit;
    font-size: .95rem;
    font-weight: 600;
    cursor: pointer;
    transition: background .2s, transform .1s;
  }
  .submit-btn:hover { background: #1e4a99; }
  .submit-btn:active { transform: scale(.98); }

  /* divider */
  .divider { border: none; border-top: 1px solid var(--border); margin: 0 28px; }

  @media (max-width: 520px) {
    .form-grid { grid-template-columns: 1fr; }
    .form-group.full { grid-column: 1; }
    .modal-header { padding: 18px 18px 14px; }
    .slots-section, .add-section { padding-left: 18px; padding-right: 18px; }
  }
  @media (max-width: 860px) {
    .app-layout {
      padding-left: 0;
    }
    .sidebar {
      position: static;
      width: 100%;
      top: auto;
      bottom: auto;
      left: auto;
      margin-bottom: 20px;
    }
    .logout-top {
      position: static;
      display: flex;
      justify-content: flex-end;
      margin-bottom: 16px;
      right: auto;
      top: auto;
    }
    .header {
      justify-content: space-between;
    }
  }
</style>
</head>
<body>

<!-- ── App layout ── -->
<div class="app-layout">
  <form action="/logout?_method=DELETE" method="post" class="logout-form logout-top">
    <button type="submit" class="logout-btn">Abmelden</button>
  </form>
  <aside class="sidebar">
    <div class="sidebar-panel">
      <div class="sidebar-title">Portal</div>
      <button class="sidebar-item active" type="button">Kalender</button>
      <button class="sidebar-item" type="button">Nachrichten</button>
      <button class="sidebar-item" type="button">Benutzerinformationen</button>
    </div>
  </aside>

  <div class="main-content">
    <!-- ── Header ── -->
    <div class="header">
      <div>
        <div class="header-title">Sprechstunden<br><span>Verwaltung <%=name%></span></div>
        <div class="header-sub">Professorenportal · Terminplanung</div>
      </div>
      <div class="month-nav">
        <button class="nav-btn" id="prevMonth">&#8249;</button>
        <div class="month-label" id="monthLabel"></div>
        <button class="nav-btn" id="nextMonth">&#8250;</button>
      </div>
    </div>

    <!-- ── Calendar ── -->
    <div class="cal-wrap">
  <div class="cal-weekdays">
    <div>Mo</div><div>Di</div><div>Mi</div><div>Do</div><div>Fr</div><div>Sa</div><div>So</div>
  </div>
  <div class="cal-grid" id="calGrid"></div>
</div>

<div class="legend">
  <div class="legend-item">
    <div class="legend-dot" style="background:var(--slot)"></div>
    Einmalige Sprechstunde
  </div>
  <div class="legend-item">
    <div class="legend-dot" style="background:var(--repeat)"></div>
    Wöchentlich wiederkehrend
  </div>
</div>
</div>
</div>

<!-- ── Day Modal ── -->
<div class="overlay" id="overlay">
  <div class="modal" id="modal">
    <div class="modal-header">
      <div>
        <h2 id="modalTitle"></h2>
        <div class="modal-date-sub" id="modalSub"></div>
      </div>
      <button class="close-btn" id="closeModal">✕</button>
    </div>

    <div class="slots-section">
      <h3>Eingetragene Sprechstunden</h3>
      <div id="slotList"></div>
    </div>

    <hr class="divider" style="margin-top:18px">

    <div class="add-section">
      <h3>Neue Sprechstunde hinzufügen</h3>
      <div class="form-grid">
        <div class="form-group">
          <label>Von</label>
          <input type="time" id="timeFrom" value="10:00">
        </div>
        <div class="form-group">
          <label>Bis</label>
          <input type="time" id="timeTo" value="11:00">
        </div>
        <div class="form-group full">
          <label>Bezeichnung (optional)</label>
          <input type="text" id="slotTitle" placeholder="z. B. Offene Sprechstunde, Prüfungsgespräch …">
        </div>
        <div class="form-group full">
          <label>Raum</label>
          <input type="text" id="slotRoom" placeholder="z. B. Gebäude A · Raum 214">
        </div>

        <!-- Repeat toggle -->
        <div class="repeat-toggle-wrap" id="repeatToggle">
          <div class="toggle-switch"></div>
          <span class="toggle-label">Wöchentliche Wiederholung</span>
          <span class="toggle-sub" id="repeatHint">aus</span>
        </div>

        <div class="form-group full" id="repeatUntilGroup" style="display:none">
          <label>Wiederholen bis</label>
          <input type="date" id="repeatUntil">
        </div>
      </div>
      <button class="submit-btn" id="addSlotBtn">Sprechstunde eintragen</button>
    </div>
  </div>
</div>


<script>
// ── State ──
const state = {
  year:  new Date().getFullYear(),
  month: new Date().getMonth(),  // 0-based
  slots: {},   // key: "YYYY-MM-DD" → [{id, from, to, title, room, repeat, repeatUntil}]
  activeDate: null,
  repeatOn: false,
};

const WEEKDAYS_DE = ['Montag','Dienstag','Mittwoch','Donnerstag','Freitag','Samstag','Sonntag'];
const MONTHS_DE   = ['Januar','Februar','März','April','Mai','Juni','Juli','August','September','Oktober','November','Dezember'];

// ── Helpers ──
function pad(n){ return String(n).padStart(2,'0'); }
function dateKey(y,m,d){ return `${y}-${pad(m+1)}-${pad(d)}`; }
function parseKey(k){ const [y,m,d]=k.split('-').map(Number); return {y,m:m-1,d}; }

function slotsForDate(key){
  const direct = state.slots[key] || [];
  // collect repeating slots from earlier dates that cover this key
  const {y,m,d} = parseKey(key);
  const targetMs = new Date(y,m,d).getTime();
  const repeating = [];
  for(const [srcKey, arr] of Object.entries(state.slots)){
    for(const slot of arr){
      if(!slot.repeat) continue;
      if(srcKey === key) continue;  // already in direct
      const src = parseKey(srcKey);
      const srcMs = new Date(src.y,src.m,src.d).getTime();
      if(srcMs >= targetMs) continue;
      const diffDays = Math.round((targetMs - srcMs)/(1000*60*60*24));
      if(diffDays % 7 !== 0) continue;
      if(slot.repeatUntil){
        const untilMs = new Date(slot.repeatUntil).getTime();
        if(targetMs > untilMs) continue;
      }
      repeating.push({...slot, _virtual: true, _srcKey: srcKey});
    }
  }
  return [...direct, ...repeating];
}

// ── cache slot data ──
async function chacheData() {
  const {year,month} = state;

  const firstDay = new Date(year, month, 1);
  // Monday-based: getDay() 0=Sun→6, 1=Mon→0 …
  let startDow = (firstDay.getDay()+6)%7; // 0=Mon
  const daysInMonth = new Date(year, month+1, 0).getDate();
  const daysInPrev  = new Date(year, month, 0).getDate();
  const total = startDow + daysInMonth;
  const trailing = (7 - (total%7)) % 7;

  // delete old slots to make room for new ones
  state.slots = {};

  // start of fetch request
  const startInPrev = daysInPrev - startDow + 1;
  // get this month's slots from backend and cache in state
  if(startDow > 0) {
    var prevKey = dateKey(month===0?year-1:year, month===0?11:month-1, startInPrev);
  } else {
    var prevKey = dateKey(year, month, 1);
  } 

  if(trailing > 0) {
    var postKey = dateKey(month===11?year+1:year, month===11?0:month+1, trailing);
  } else {
    var postKey = dateKey(year, month, daysInMonth);
  }

  const params = new URLSearchParams();
  params.append("startDate", prevKey);
  params.append("endDate", postKey);

  try {
    const response = await fetch(`/api/slot_data?${params}`);
    
    if(response.status === 204) {
      console.log('Keine Slot-Daten gefunden für diesen Zeitraum.');
      return;
    }

    const data = await response.json();

    if(!response.ok) {
      console.log(response);
      return;
    }
    data.forEach(slot => {
      const key = slot.date;
      if(!state.slots[key]) state.slots[key] = [];
      state.slots[key].push({
        id: slot.id, 
        from: slot.from, 
        to: slot.to, 
        title: slot.title, 
        room: slot.room, 
        repeat: slot.repeat, 
        repeatUntil: slot.repeatUntil
      });
    });

  } catch (e) {
    alert(e)
  }
}


// ── Render Calendar ──
function renderCalendar(){
  const {year,month} = state;
  document.getElementById('monthLabel').textContent = `${MONTHS_DE[month]} ${year}`;

  const grid = document.getElementById('calGrid');
  grid.innerHTML = '';

  const today = new Date();
  const firstDay = new Date(year, month, 1);
  // Monday-based: getDay() 0=Sun→6, 1=Mon→0 …
  let startDow = (firstDay.getDay()+6)%7; // 0=Mon
  const daysInMonth = new Date(year, month+1, 0).getDate();
  const daysInPrev  = new Date(year, month, 0).getDate();

  // fill leading empties with prev month days
  for(let i=0;i<startDow;i++){
    const d = daysInPrev - startDow + 1 + i;
    const cell = makeCell(year, month-1, d, true);
    grid.appendChild(cell);
  }
  for(let d=1; d<=daysInMonth; d++){
    const isToday = (today.getFullYear()===year && today.getMonth()===month && today.getDate()===d);
    const cell = makeCell(year, month, d, false, isToday);
    grid.appendChild(cell);
  }
  // fill trailing
  const total = startDow + daysInMonth;
  const trailing = (7 - (total%7)) % 7;
  for(let d=1; d<=trailing; d++){
    const cell = makeCell(year, month+1, d, true);
    grid.appendChild(cell);
  }
}

function makeCell(y, m, d, other, isToday){
  const el = document.createElement('div');
  el.className = 'cal-cell' + (other?' other-month':'') + (isToday?' today':'');

  const dn = document.createElement('div');
  dn.className = 'day-num';
  dn.textContent = d;
  el.appendChild(dn);

  // real month key
  const realY = m<0 ? y-1 : (m>11 ? y+1 : y);
  const realM = ((m%12)+12)%12;
  const key = dateKey(realY, realM, d);

  const slots = slotsForDate(key);
  const MAX_SHOW = 2;
  slots.slice(0, MAX_SHOW).forEach(s=>{
    const pill = document.createElement('div');
    pill.className = 'slot-pill' + (s.repeat||s._virtual?' repeat':'');
    pill.innerHTML = `<span class="dot"></span>${s.from}–${s.to}${s.title?' · '+s.title:''}`;
    el.appendChild(pill);
  });
  if(slots.length > MAX_SHOW){
    const more = document.createElement('div');
    more.className='more-slots';
    more.textContent=`+${slots.length-MAX_SHOW} weitere`;
    el.appendChild(more);
  }

  el.addEventListener('click', ()=> openModal(realY, realM, d));
  return el;
}

// ── Modal ──
function openModal(y, m, d){
  state.activeDate = {y,m,d};
  const key = dateKey(y,m,d);
  const dateObj = new Date(y,m,d);
  const dow = WEEKDAYS_DE[(dateObj.getDay()+6)%7];

  document.getElementById('modalTitle').textContent =
    `${dow}, ${d}. ${MONTHS_DE[m]} ${y}`;
  document.getElementById('modalSub').textContent =
    'Sprechstunden für diesen Tag';

  // default repeatUntil = end of semester (~3 months)
  const until = new Date(y,m+3,d);
  document.getElementById('repeatUntil').value =
    `${until.getFullYear()}-${pad(until.getMonth()+1)}-${pad(until.getDate())}`;

  renderSlotList(key);
  document.getElementById('overlay').classList.add('open');
}

function renderSlotList(key){
  const list = document.getElementById('slotList');
  list.innerHTML='';
  const slots = slotsForDate(key);

  if(!slots.length){
    list.innerHTML='<div class="no-slots">Noch keine Sprechstunden eingetragen.</div>';
    return;
  }

  slots.forEach(s=>{
    const row = document.createElement('div');
    row.className='slot-row';
    row.innerHTML=`
      <div class="time-badge">${s.from} – ${s.to}</div>
      <div class="slot-title-text">${s.title||'Sprechstunde'}${s.room?' <span style="color:var(--muted);font-size:.78rem">· '+s.room+'</span>':''}</div>
      ${s.repeat||s._virtual?'<div class="repeat-badge">↻ wöchentl.</div>':''}
      ${!s._virtual?`<button class="delete-slot" title="Löschen" data-key="${s._srcKey||key}" data-id="${s.id}">✕</button>`:''}
    `;
    const del = row.querySelector('.delete-slot');
    if(del) del.addEventListener('click', async (e)=>{
      e.stopPropagation();
      deleteSlot(del.dataset.key, del.dataset.id);
    });
    list.appendChild(row);
  });
}

async function deleteSlot(key, id){
  if(!state.slots[key]) return;
  
  try {
    const res = await fetch('/api/slot_data', {
        method: 'DELETE',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({id: id})
      }
    )

    if(!res.ok) {
      console.log(res)
      alert('Fehler beim Löschen')
      return 
    }

    state.slots[key] = state.slots[key].filter(s=>s.id!==id);
    if(!state.slots[key].length) delete state.slots[key];

  } catch (e) {
    console.log(e)
    alert('Fehler beim Löschen')
  }

  const {y,m,d} = state.activeDate;
  renderSlotList(dateKey(y,m,d));
  renderCalendar();
}

function closeModal(){
  document.getElementById('overlay').classList.remove('open');
  state.repeatOn = false;
  document.getElementById('repeatToggle').classList.remove('active');
  document.getElementById('repeatHint').textContent='aus';
  document.getElementById('repeatUntilGroup').style.display='none';
  document.getElementById('slotTitle').value='';
  document.getElementById('slotRoom').value='';
  document.getElementById('timeFrom').value='10:00';
  document.getElementById('timeTo').value='11:00';
}

// ── Add slot ──
document.getElementById('addSlotBtn').addEventListener('click', async ()=>{
  const {y,m,d} = state.activeDate;
  const key = dateKey(y,m,d);
  const from = document.getElementById('timeFrom').value;
  const to   = document.getElementById('timeTo').value;
  const title= document.getElementById('slotTitle').value.trim();
  const room = document.getElementById('slotRoom').value.trim();
  const repeat = state.repeatOn;
  const repeatUntil = repeat ? document.getElementById('repeatUntil').value : null;

  if(!from||!to){ alert('Bitte Anfangs- und Endzeit angeben.'); return; }
  if(from>=to){ alert('Die Endzeit muss nach der Startzeit liegen.'); return; }

  try {
    const response = await fetch('/api/slot_data', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify(
        {
          date: key,
          from: from,
          to: to,
          title: title,
          room: room,
          repeat: repeat,
          repeatUntil: repeatUntil
        }
      )
    })

    const data = await response.json()

    if(!response.ok) {
      alert('Hinzufügen fehlgeschlagen!')
      console.log(response, data)
      return
    }

    if(!state.slots[key]) state.slots[key]=[];
    state.slots[key].push({
      id: data.id,
      from, to, title, room, repeat, repeatUntil
    });

  } catch (error) {
    alert('Hinzufügen fehlgeschlagen!')
    console.log(error)
  }

  renderSlotList(key);
  renderCalendar();

  // reset form
  document.getElementById('slotTitle').value='';
  document.getElementById('slotRoom').value='';
  document.getElementById('timeFrom').value='10:00';
  document.getElementById('timeTo').value='11:00';
  // keep repeat toggle as-is for convenience
});

// ── Repeat toggle ──
document.getElementById('repeatToggle').addEventListener('click', ()=>{
  state.repeatOn = !state.repeatOn;
  const tog = document.getElementById('repeatToggle');
  const hint = document.getElementById('repeatHint');
  const urg  = document.getElementById('repeatUntilGroup');
  tog.classList.toggle('active', state.repeatOn);
  hint.textContent = state.repeatOn ? 'ein' : 'aus';
  urg.style.display = state.repeatOn ? 'block' : 'none';
});

// ── Nav ──
document.getElementById('prevMonth').addEventListener('click', async ()=>{
  state.month--;
  if(state.month<0){ state.month=11; state.year--; }
  await chacheData();
  renderCalendar();
});
document.getElementById('nextMonth').addEventListener('click', async()=>{
  state.month++;
  if(state.month>11){ state.month=0; state.year++; }
  await chacheData();
  renderCalendar();
});

document.getElementById('closeModal').addEventListener('click', closeModal);
document.getElementById('overlay').addEventListener('click', e=>{
  if(e.target===document.getElementById('overlay')) closeModal();
});

// ── Init ──
chacheData().then(()=>{
  renderCalendar();
});
</script>
</body>
</html>